---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import raw from "./books.csv?raw";

const lines = raw
	.trim()
	.split("\n")
	.filter((line) => line.trim() !== "");
const headers = lines[0].split(",");
const books = lines.slice(1).map((line) => {
	const values = line.split(",");
	return Object.fromEntries(
		headers.map((h, i) => [h.trim(), values[i]?.trim() ?? ""]),
	);
});
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title="蔵書一覧(工事中)" description="持ってる本の一覧" />
		<style>
			h1 {
				font-size: 2rem;
				margin-bottom: 1rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>蔵書一覧(工事中)</h1>
			<p>僕の持ってる本の一覧、読みたい人がいれば貸します。</p>
			<div style="margin-left: 2rem;">
				{
					books.map((book) => (
						<>
							<img
								src={`https://ndlsearch.ndl.go.jp/thumbnail/${book.isbn}.jpg`}
								alt={book.title}
								width="100"
								height="150"
							/>
							<div style="margin-bottom: 2rem;">
								<h2>・{book.title} </h2>
								<p style="margin-left: 2rem;">
									著者: {book.author}
								</p>
								<p style="margin-left: 2rem;">{book.comment}</p>
							</div>
						</>
					))
				}
			</div>
			<p>
				表紙画像は国立国会図書館サーチの書影APIから取得しており、出版情報登録センターから提供されたものです。<br
				/>ライセンスは<a
					href="https://creativecommons.org/licenses/by/4.0/deed.ja"
					>クリエイティブ・コモンズ 表示 4.0 国際
					パブリック・ライセンス</a
				>です。
			</p>
		</main>

		<Footer />
	</body>
</html>
