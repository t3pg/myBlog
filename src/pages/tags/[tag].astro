---
import { type CollectionEntry, getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import Sidebar from "../../components/Sidebar.astro";
import { SITE_TITLE } from "../../consts";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	const tagSet = new Set<string>();
	posts.forEach((post) => {
		(post.data.tags ?? []).forEach((tag) => tagSet.add(tag));
	});
	return [...tagSet].map((tag) => ({
		params: { tag },
		props: { tag },
	}));
}

interface Props {
	tag: string;
}

const { tag } = Astro.props;

const allPosts = await getCollection("blog");
const posts = allPosts
	.filter((post) => post.data.tags?.includes(tag))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tagEntries = await getCollection("tags");
const tagEntry = tagEntries.find((t) => t.id === tag);
const description = tagEntry?.data.description ?? "";
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`${tag} | ${SITE_TITLE}`}
			description={description || `${tag} タグの記事一覧`}
		/>
		<style>
			.tag-heading {
				display: flex;
				align-items: baseline;
				gap: 0.5em;
				margin-bottom: 0.25em;
			}
			.tag-heading h1 {
				margin: 0;
			}
			.post-count {
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			.description {
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			ul li a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1em;
				text-decoration: none;
				padding: 0.75em 1em;
				border-radius: 8px;
				transition: background 0.15s;
			}
			ul li a:hover {
				background: rgb(var(--gray-light));
			}
			.post-title {
				color: rgb(var(--black));
				font-weight: 600;
				line-height: 1.3;
			}
			ul li a:hover .post-title {
				color: var(--accent);
			}
			.post-date {
				color: rgb(var(--gray));
				font-size: 0.85em;
				white-space: nowrap;
				flex-shrink: 0;
			}
			.back {
				display: inline-block;
				margin-top: 2em;
				color: rgb(var(--gray));
				font-size: 0.9em;
				text-decoration: none;
			}
			.back:hover {
				color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="layout-wrapper">
		<main>
			<div class="tag-heading">
				<h1>{tag}</h1>
				<span class="post-count">{posts.length} 件</span>
			</div>
			{description && <p class="description">{description}</p>}
			<ul>
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id.split("/").pop()}/`}>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						</li>
					))
				}
			</ul>
			<a class="back" href="/tags/">← タグ一覧へ</a>
		</main>
		<Sidebar />
		</div>
		<Footer />
	</body>
</html>
